{
  "manifest_version": 2,
  "name": "Tab Mirror",
  "version": "0.1.0",
  "default_locale": "en",
  "description": "__MSG_extensionDescription__",
  "permissions": [
    "tabs",
    "storage",
    "sessions",
    "idle",
    "tabGroups",
    "webNavigation",
    "notifications",
    "theme",
    "cookies",
    "contextualIdentities",
    "https://*.peerjs.com/*"
  ],
  "content_security_policy": "script-src 'self'; object-src 'self'; connect-src 'self' wss://*.peerjs.com https://*.peerjs.com;",
  "browser_specific_settings": {
    "gecko": {
      "id": "tab-mirror-extension@mrericsir.com",
      "strict_min_version": "139.0"
    }
  },
  "background": {
    "scripts": [
      "peerjs.min.js",
      "bimap.js",
      "background.js",
      "crypto.js",
      "pairing.js",
      "transport.js",
      "sync-engine.js",
      "message-external.js",
      "message-internal.js",
      "init-helpers.js",
      "init.js"
    ]
  },
  "browser_action": {
    "default_title": "Tab Mirror",
    "default_popup": "popup.html",
    "default_icon": "icons/icon-light.svg",
    "theme_icons": [
      {
        "light": "icons/icon-light.svg",
        "dark": "icons/icon-dark.svg",
        "size": 24
      }
    ]
  }
}
